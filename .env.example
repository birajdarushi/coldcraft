# LLM for draft/intel generation (Google Gemini).
# Optional here — can also be set at runtime under Settings → API Keys.
# Get a key at https://aistudio.google.com/apikey
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash

# Fernet key for SMTP password encryption at rest
# Generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
GTM_SMTP_ENCRYPTION_KEY=your-fernet-key-here

# Database (docker-compose sets this automatically for the api service)
DATABASE_URL=postgresql://gtm:gtm@localhost:5432/gtm

# Dev SMTP defaults (Mailpit — use `python scripts/dev_up.py` to start)
SMTP_HOST=mailpit
SMTP_PORT=1025
SMTP_USER=coldcraft
FROM_EMAIL=coldcraft@localhost
FROM_NAME=Coldcraft Dev

# Login OTP delivery. Defaults to 'mailpit' (capture locally) when no
# SMTP_PASS_ENC is set; set OTP_DELIVERY_MODE=smtp + SMTP_PASS_ENC for real
# email. SMTP_PASS_ENC is a Fernet-encrypted SMTP password (see secrets.py).
# OTP_DELIVERY_MODE=smtp
# SMTP_PASS_ENC=