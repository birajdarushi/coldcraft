# LLM for draft/intel generation (Google Gemini).
# Optional here — can also be set at runtime under Settings → API Keys.
# Get a key at https://aistudio.google.com/apikey
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash

# Fernet key for SMTP password encryption at rest
# Generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
GTM_SMTP_ENCRYPTION_KEY=your-fernet-key-here

# Database (docker-compose sets this automatically for the api service)
DATABASE_URL=postgresql://gtm:gtm@localhost:5432/gtm

# Dev SMTP defaults (Mailpit — use `python scripts/dev_up.py` to start)
SMTP_HOST=mailpit
SMTP_PORT=1025
SMTP_USER=coldcraft
FROM_EMAIL=coldcraft@localhost
FROM_NAME=Coldcraft Dev

# Login OTP delivery. Defaults to 'mailpit' (capture locally) when no
# SMTP_PASS_ENC is set; set OTP_DELIVERY_MODE=smtp + SMTP_PASS_ENC for real
# email. SMTP_PASS_ENC is a Fernet-encrypted SMTP password (see secrets.py).
# OTP_DELIVERY_MODE=smtp
# SMTP_PASS_ENC=

# Google OAuth Client Credentials (for Gmail connection in Inbox Hub)
GOOGLE_CLIENT_ID=your-google-client-id-here
GOOGLE_CLIENT_SECRET=your-google-client-secret-here

# GitHub OAuth App credentials (for GitHub integration in Settings → Integrations)
# Create an OAuth App at https://github.com/settings/developers
# Callback URL to register: https://your-api-domain/api/v1/integrations/github/callback
GITHUB_CLIENT_ID=your-github-client-id-here
GITHUB_CLIENT_SECRET=your-github-client-secret-here

# The public URL of this API service (used to build the GitHub callback URL)
# In dev: http://localhost:8000 (default). In prod: https://your-api-domain
# API_BASE_URL=http://localhost:8000

# The public URL of the frontend (used to redirect the browser after OAuth)
# In dev: http://localhost:5173 (default). In prod: https://your-frontend-domain
# FRONTEND_ORIGIN=http://localhost:5173